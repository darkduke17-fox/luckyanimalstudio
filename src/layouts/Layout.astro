---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = '吉祥物工作室',
  description = '親愛的冒險者您好，歡迎來到吉祥物工作室，一間存在於現實夾縫中的小小道具屋～提供天然水晶、奧剛工藝、命理占卜與薩滿療癒服務。',
  image = '/images/logo.png',
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString() : 'http://localhost:4321';
const absoluteImageUrl = new URL(image, siteUrl).toString();
const absolutePageUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a1412" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={absolutePageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={absolutePageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImageUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="site-logo" href="/" aria-label="回到幸運獸冒險者公會首頁">
          <img src="/images/logo.png" alt="幸運獸冒險者公會標誌" width="96" height="96" />
        </a>
        <div class="site-welcome">
          <p class="site-kicker">Lucky Animal Studio</p>
          <h1>歡迎來到吉祥物工作室</h1>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-blessing">
          <span aria-hidden="true">✦</span>
          祝願每位冒險者都能找到，專屬於自己的道標。
          <span aria-hidden="true">✦</span>
        </div>
        <div class="footer-credits">Designed &amp; Built by AzureBear</div>
      </footer>
    </div>
  </body>
</html>
