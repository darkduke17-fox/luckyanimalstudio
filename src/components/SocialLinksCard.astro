---
import type { CardSize, SocialPlatform } from '../data/schema';

interface Props {
  links: Array<{ platform: SocialPlatform; url: string }>;
  size: CardSize;
}

const { links, size } = Astro.props;
const platformLabels: Record<SocialPlatform, string> = {
  line: 'LINE',
  facebook: 'Facebook',
  instagram: 'Instagram',
};
const singlePlatform = links.length === 1 ? links[0]?.platform : undefined;
const heading = singlePlatform ? platformLabels[singlePlatform] : '公會傳訊';
---

<article class:list={['bento-card', `${size}-span`, 'social-card']}>
  <p class="eyebrow">Guild Dispatch</p>
  <h2 class="card-section-title">{heading}</h2>
  <nav class="social-links" aria-label="社群連結">
    {links.map((link) => (
      <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={`前往 ${platformLabels[link.platform]}`}>
        <span class="social-mark" aria-hidden="true">{platformLabels[link.platform].slice(0, 1)}</span>
        <span>前往 {platformLabels[link.platform]}</span>
      </a>
    ))}
  </nav>
</article>
